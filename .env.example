# --- Chat model (Groq, free, hosted) ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_CHAT_MODEL=llama-3.1-8b-instant

# --- Embeddings ---
# Runs locally inside the server with @xenova/transformers.
# No API key needed.

# --- Local "vector database" ---
DB_PATH=./data/docs.db

# --- Corpus ---
CORPUS_SITEMAP_URL=https://fastapi.tiangolo.com/sitemap.xml
CORPUS_NAME=FastAPI Documentation

# --- Retrieval / cost controls ---
TOP_K=5
MAX_CHUNKS_PER_QUERY=5
CHUNK_TARGET_TOKENS=650
CHUNK_OVERLAP_TOKENS=80

# --- Retrieval quality threshold ---
# NOTE: all-MiniLM-L6-v2 cosine scores run lower than nomic-embed-text's.
# These thresholds are recalibrated for the new model.
MIN_RETRIEVAL_SCORE=0.30
MIN_TOP_RETRIEVAL_SCORE=0.25

# --- Follow-up / multi-turn context ---
# Number of recent messages (~ last few turns) kept as conversation
# context: used both to rewrite follow-up questions into standalone
# search queries for retrieval, and as the LLM's own chat memory.
HISTORY_MESSAGES=6
